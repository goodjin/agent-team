{
  "name": "agent-team",
  "version": "2.0.0",
  "description": "以任务为中心的多智能体协作系统",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "server": "tsx src/index.ts",
    "cli": "tsx src/ui/cli/index.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --exclude tests/v9/e2e.test.ts",
    "test:e2e": "vitest run tests/v9/e2e.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mime-types": "^2.1.35",
    "openai": "^6.22.0",
    "uuid": "^9.0.1",
    "ws": "^8.14.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.2",
    "vitest": "^4.1.0"
  }
}
